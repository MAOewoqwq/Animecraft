# 复制本文件为 .env 并填入你自己的 API Key。
# .env 已被 .gitignore 忽略,不会提交到仓库。
#
# 读取优先级:keys.json > .env / 环境变量。
# 所以你可以二选一:用 keys.json,或用本 .env —— 两者可共存。
# 只需填你实际用到的服务,其余留空即可。

# --- 本仓库当前默认用到的 ---
DEEPSEEK_API_KEY=
FISHAUDIO_API_KEY=

